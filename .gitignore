# --------------------------------------------------------------------------- #
# Python.
# --------------------------------------------------------------------------- #
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
*.whl
pip-wheel-metadata/

# --------------------------------------------------------------------------- #
# Virtual environments and tooling caches.
# --------------------------------------------------------------------------- #
.venv/
venv/
env/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --------------------------------------------------------------------------- #
# uv.
# uv.lock is committed (reproducible builds); only caches are ignored.
# --------------------------------------------------------------------------- #
.uv-cache/

# --------------------------------------------------------------------------- #
# IDEs and editors.
# --------------------------------------------------------------------------- #
.idea/
.vscode/
*.swp
*.swo
*~

# --------------------------------------------------------------------------- #
# macOS.
# --------------------------------------------------------------------------- #
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# --------------------------------------------------------------------------- #
# Project-local debug artefacts.
# --------------------------------------------------------------------------- #
/debug_out/
/scratch/
*.log
# scikit-build-core writes incremental build state here; it is
# regenerated by `uv sync` and must never be committed.
/build/
